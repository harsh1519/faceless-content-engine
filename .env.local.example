# Supabase — create a project at https://supabase.com/dashboard
# Project Settings → API → URL and anon key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role — Project Settings → API → service_role (server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Gemini — https://aistudio.google.com/apikey (free tier)
GEMINI_API_KEY=your-gemini-api-key-here

# ElevenLabs — https://elevenlabs.io (free tier)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
# Optional voice override (defaults to Rachel)
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Pexels — https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-api-key-here

# Auth: enable Email provider in Supabase Dashboard → Authentication → Providers
# Disable "Confirm email" for quick local dev, or confirm via Supabase email logs
